# Normalize line endings to LF on checkout
* text=auto eol=lf

# Windows-specific files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly declare binary files to prevent corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.jar binary
*.class binary
*.zip binary
*.tar binary
*.gz binary
